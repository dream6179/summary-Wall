// ==========================================================================
// 🧙‍♂️ 輕量級安全防卡死 RSS 解析器（兩步拆解自癒版 - 完整相容 RSS 與 Google 快訊 Atom）
// ==========================================================================
function parseRssToJSON(xmlText, sourceName, defaultTagName) {
  const items = [];
  const itemRegex = /<(item|entry)>([\s\S]*?)<\/\1>/g;
  let match;
  
  const cleanCdata = (str) => {
    if (!str) return "";
    return str.replace(/<!\[CDATA\[([\s\S]*?)\]\]>/gi, "$1").trim();
  };

  while ((match = itemRegex.exec(xmlText)) !== null) {
    const itemContent = match[2]; 
    
    // 🎯 升級相容標籤：允許標籤內部帶有 type 等屬性（專治 Google 快訊屬性阻斷）
    const titleMatch = itemContent.match(/<title[^>]*>([\s\S]*?)<\/title>/i);
    const linkMatch = itemContent.match(/<link[^>]*href=["']([^"']+)["']|<link>([\s\S]*?)<\/link>/i);
    const descMatch = itemContent.match(/<(description|summary|content)[^>]*>([\s\S]*?)<\/\1>/i);
    const pubDateMatch = itemContent.match(/<(pubDate|updated|published|issued)[^>]*>([\s\S]*?)<\/\1>/i);
    
    const title = cleanCdata(titleMatch ? titleMatch[1] : "");
    const link = linkMatch ? (linkMatch[1] || linkMatch[2] || "") : "";
    const description = cleanCdata(descMatch ? descMatch[2] : "");
    const pubDate = pubDateMatch ? pubDateMatch[2] : "";

    // 🎯 萬用原圖掏挖：相容標準媒體與網頁擴展 img 格式
    let imageUrl = "";
    const mediaMatch = itemContent.match(/<(media:content|media:thumbnail|enclosure)[^>]+url=["']([^"']+)["']/i);
    if (mediaMatch) {
      imageUrl = mediaMatch[2];
    } else {
      const imgMatch = description.match(/src=["'](https?:\/\/[^"']+)["']/i);
      if (imgMatch) imageUrl = imgMatch[1];
    }

    // 🎯 滿血回歸：時間與時間戳動態計算引擎
    let timestamp = Date.now(); 
    let displayTime = "更新";
    if (pubDate) {
      try {
        const dateObj = new Date(pubDate.trim());
        if (!isNaN(dateObj.getTime())) { 
          timestamp = dateObj.getTime(); 
          displayTime = dateObj.toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit', hour12: false }); 
        }
      } catch (e) {}
    }
    
    const cleanSnippet = description.replace(/<[^>]*>/g, '').replace(/&nbsp;/g, ' ').trim();
    
    items.push({
      id: `news-${Math.random().toString(36).substring(2, 9)}`,
      tag: defaultTagName, 
      isFeatured: false, 
      isImportant: items.length < 2,
      title: title, 
      snippet: cleanSnippet.substring(0, 120) + (cleanSnippet.length > 120 ? "..." : ""),
      source: sourceName, 
      time: displayTime, 
      link: link, 
      timestamp: timestamp, 
      image: imageUrl
    });
  }
  return items;
}
