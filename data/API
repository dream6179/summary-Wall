[新聞內容]
標題：${aiTitle}
摘要：${aiSnippet}

[正式報告本體]` 
                }] 
              }
            ],
            generationConfig: {
              maxOutputTokens: 2048,
              temperature: 0.68
            }
          })
        });

        if (!googleResponse.ok) {
          const errorData = await googleResponse.json();
          throw new Error(errorData.error?.message || `Google API 回傳錯誤: ${googleResponse.status}`);
        }

        const fullJsonText = await googleResponse.text();

        let rawAiText = "";
        try {
          const parsed = JSON.parse(fullJsonText);
          if (Array.isArray(parsed)) {
            rawAiText = parsed.map(chunk => chunk.candidates?.[0]?.content?.parts?.[0]?.text || "").join("");
          } else {
            rawAiText = parsed.candidates?.[0]?.content?.parts?.[0]?.text || "";
          }
        } catch (jsonErr) {
          const textMatches = [...fullJsonText.matchAll(/"text":\s*"(.*?)"/g)];
          rawAiText = textMatches.map(m => m[1]).join("");
        }

        let cleanedText = rawAiText.trim();
        const thoughtLineRegex = /^\s*[\*\-\d\.]*\s*\*?\*?\b(role|task|section|check|constraint|requirement|input|output|formatting|thought|outline|analyst|surface|professional|tone|words?|count)\b.*/gim;
        
        let lastThoughtEndIdx = 0;
        let match;
        while ((match = thoughtLineRegex.exec(cleanedText)) !== null) {
          lastThoughtEndIdx = match.index + match[0].length;
        }

        if (lastThoughtEndIdx > 0) {
          const remainingText = cleanedText.substring(lastThoughtEndIdx);
          const firstChineseIdx = remainingText.search(/[\u4e00-\u9fa5]/);
          
          if (firstChineseIdx !== -1) {
            let startSliceIdx = firstChineseIdx;
            const lookbackStr = remainingText.substring(Math.max(0, firstChineseIdx - 5), firstChineseIdx);
            const markerMatch = lookbackStr.match(/([\*【#]+)$/);
            if (markerMatch) {
              startSliceIdx = firstChineseIdx - markerMatch[1].length;
            }
            cleanedText = remainingText.substring(startSliceIdx);
          } else {
            cleanedText = remainingText;
          }
        } else {
          const firstChineseIdx = cleanedText.search(/[\u4e00-\u9fa5]/);
          if (firstChineseIdx !== -1) {
            cleanedText = cleanedText.substring(firstChineseIdx);
          }
        }

        cleanedText = cleanedText.trim();
        const safeTextForJson = JSON.stringify(cleanedText);
        const finalResponsePayload = `{"candidates":[{"content":{"parts":[{"text":${safeTextForJson}}]}}]}`;

