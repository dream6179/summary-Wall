// 🧙‍♂️ 💥【黑科技：全量最新頭條圖文 - 背景自動預熱發電引擎】
// ==========================================================================
async function preheatAllNewsEngine(newsList, env) {
  if (!newsList || newsList.length === 0) return;

  console.log(`🚀 [全量預熱點火] 本次拉回 ${newsList.length} 篇新聞，開始進行全自動背景圖文連鎖上架...`);

  for (const item of newsList) {
    const textCacheKey = "ai_summary:" + encodeURIComponent(item.title).substring(0, 150);
    const imgCacheKey = "ai_cover:" + encodeURIComponent(item.title).substring(0, 150);

    // 1. 先翻口袋：檢查是否早就已經存在
    const hasText = await env.NEWS_CACHE_KV.get(textCacheKey);
    const hasImg = await env.NEWS_CACHE_KV.get(imgCacheKey);

    // 💡 智慧分流：如果圖文早就在快取裡，直接跳過，絕不重複浪費點數
    if (hasText && hasImg) {
      continue;
    }

    let triggeredThisTurn = false;

    // 2. 🧠 預熱 A 核心：只要快取沒文字，後台默默呼叫 Gemma 31B 脆友閒聊核心
    if (!hasText) {
      try {
        const aiReportPayload = await callGemmaKolEngine(item.title, item.snippet, env);
        if (aiReportPayload) {
          await env.NEWS_CACHE_KV.put(textCacheKey, aiReportPayload, { expirationTtl: 2592000 });
          triggeredThisTurn = true;
        }
      } catch (err) {
        console.error(`[預熱失敗] 文字生成中斷: ${item.title} ->`, err.message);
      }
    }

    // 3. 🎨 預熱 B 核心：只要快取沒圖片，後台默默驚動 AI 封面生圖核心
    if (!hasImg) {
      try {
        const aiCoverPayload = await callAiCoverGenerator(item.title, env);
        if (aiCoverPayload) {
          await env.NEWS_CACHE_KV.put(imgCacheKey, aiCoverPayload, { expirationTtl: 2592000 });
          triggeredThisTurn = true;
        }
      } catch (err) {
        console.error(`[預熱失敗] 封面生成中斷: ${item.title} ->`, err.message);
      }
    }

    // 4. 🛡️ 【最核心安全帶】：強迫每處理完一篇文章就原地休息 3 秒，避開 Google 每分鐘 (RPM) 頻率限制
    if (triggeredThisTurn) {
      await new Promise(resolve => setTimeout(resolve, 3000));
    }
  }
  console.log("🏁 [全量預熱完畢] 邊緣 KV 庫庫全數塞滿！全台大廳隨時迎接入場秒開！");
}

